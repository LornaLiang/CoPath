# SQLite business database is configured by the application.

# Neo4j knowledge graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_with_your_password
NEO4J_DATABASE=neo4j

# AI assistant mode: mock for offline system tests, openai for real providers.
AI_MODE=mock

# OpenAI or an OpenAI-compatible provider
OPENAI_API_KEY=replace_with_your_api_key
# Keep the official endpoint below, or replace it with a compatible /v1 endpoint.
OPENAI_BASE_URL=https://api.openai.com/v1
# Use json_object if a compatible provider does not support strict JSON Schema.
OPENAI_RESPONSE_FORMAT=json_schema
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=1
